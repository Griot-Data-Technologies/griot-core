# Griot scaffold configuration
# Generated by Griot scaffold on {{ generated_at }}
# Contract: {{ contract_id }}

contract_id: "{{ contract_id }}"
target: "{{ target }}"
orchestrator: "{{ orchestrator }}"
source: "{{ source }}"
profile: "{{ profile | default('default') }}"

registry:
  url: "{{ registry_url }}"
  # Authenticate pipelines via environment variables:
  #   GRIOT_SA_CLIENT_ID  – service account client ID
  #   GRIOT_SA_SECRET     – service account client secret
  # Or run: griot auth login --service-account

schemas:
{% for schema in schemas %}
  - name: "{{ schema.name }}"
    table: "{{ schema.table_name }}"
{% endfor %}

scaffold:
  generated_at: "{{ generated_at }}"
  components:
{% for component in components %}
    - {{ component }}
{% endfor %}
